# Copy this file to .streamlit\secrets.toml before selecting Databricks in the sidebar.
# Do not commit secrets.toml or access tokens.
[databricks]
server_hostname = "adb-xxxxxxxxxxxxxxxx.x.azuredatabricks.net"
http_path = "/sql/1.0/warehouses/xxxxxxxxxxxxxxxx"
access_token = "replace-with-a-databricks-personal-access-token"

# The query must return these exact aliases:
# event_time (TIMESTAMP), operation_count (NUMBER), flow_name (STRING), status (STRING).
dashboard_query = """
SELECT
  event_time,
  operation_count,
  flow_name,
  status
FROM main.operations.sap_operation_events
WHERE event_time >= current_timestamp() - INTERVAL 24 HOURS
ORDER BY event_time DESC
"""
