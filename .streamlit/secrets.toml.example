# Copy this file to .streamlit\secrets.toml and fill in the real values.
# Never commit .streamlit\secrets.toml or production credentials.

[databricks]
server_hostname = "adb-xxxxxxxxxxxxxxxx.x.azuredatabricks.net"
http_path = "/sql/1.0/warehouses/xxxxxxxxxxxxxxxx"
access_token = "replace-with-a-databricks-access-token"

# Required aliases: event_time and operation_count.
# Return at least seven days for the dashboard trend.
operations_query = """
SELECT
  CAST(operation_timestamp AS TIMESTAMP) AS event_time,
  SUM(operation_count) AS operation_count
FROM main.operations.sap_operation_events
WHERE operation_timestamp >= current_timestamp() - INTERVAL 7 DAYS
GROUP BY CAST(operation_timestamp AS TIMESTAMP)
ORDER BY event_time DESC
"""

[sharepoint]
# Microsoft Entra application credentials. The app needs read access to the
# configured SharePoint drive. Prefer least-privilege site/file permissions.
tenant_id = "00000000-0000-0000-0000-000000000000"
client_id = "00000000-0000-0000-0000-000000000000"
client_secret = "replace-with-an-entra-app-secret"
drive_id = "replace-with-the-sharepoint-document-library-drive-id"

# Flow Status Excel. Required columns after alias normalization:
# flow_name, status, last_run. Optional: operation_count,
# attention_required, attention_reason.
flow_excel_path = "/AI-Operations/flow_status.xlsx"
flow_sheet_name = "FlowStatus"

# Live Activity folder. CSV and TXT files must contain:
# event_time, flow_name, status. Optional: event_type, operation_count, message.
activity_folder = "/AI-Operations/Activity"
activity_max_files = 20
